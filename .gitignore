# ============================================================
# StratumIQ — Monorepo .gitignore
# Spring Boot (backend) + Next.js (frontend)
# ============================================================


# ─────────────────────────────────────────
# ENVIRONMENT & SECRETS (never commit)
# ─────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.jks


# ─────────────────────────────────────────
# BACKEND — Spring Boot / Maven
# ─────────────────────────────────────────

# Maven build output
backend/target/

# Maven wrapper (Windows-specific)
backend/mvnw.cmd

# IDE files
backend/.idea/
backend/*.iml
backend/*.ipr
backend/*.iws

# Spring Boot logs
backend/*.log
backend/logs/

# Uploaded files (handled by Cloudinary, not disk)
backend/uploads/

# OS
backend/.DS_Store
backend/Thumbs.db


# ─────────────────────────────────────────
# FRONTEND — Next.js / Node
# ─────────────────────────────────────────

# Dependencies
frontend/node_modules/

# Next.js build output
frontend/.next/
frontend/out/

# Next.js cache
frontend/.cache/

# TypeScript build info
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# Vercel (if deploying there)
frontend/.vercel/

# OS
frontend/.DS_Store
frontend/Thumbs.db


# ─────────────────────────────────────────
# GLOBAL
# ─────────────────────────────────────────

# OS junk
.DS_Store
Thumbs.db
Desktop.ini

# Editor configs (optional: keep if team uses same IDE)
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test coverage reports
coverage/
*.lcov