################################################################################
# StratumIQ Backend Environment Configuration
# 
# ⚠️  IMPORTANT: Copy this file to .env and fill in VALUES (never commit .env)
# 
# This file is a TEMPLATE. It should NOT contain real secrets.
# For production, use:
#   - AWS Secrets Manager
#   - Kubernetes Secrets
#   - HashiCorp Vault
#   - CI/CD secrets management
# 
# Development: Copy this file to .env and fill with dev values
# Production: Use CI/CD or secrets management to inject values
################################################################################

################################################################################
# DATABASE CONFIGURATION
################################################################################

# PostgreSQL Connection URL
# Development: jdbc:postgresql://localhost:5432/stratumiq
# Production: jdbc:postgresql://prod-db.example.com:5432/stratumiq
DB_URL=jdbc:postgresql://localhost:5432/stratumiq

# Database User
DB_USER=postgres

# Database Password
# ⚠️  GENERATE A STRONG PASSWORD:
#    openssl rand -base64 16
# DO NOT use default or weak passwords
DB_PASSWORD=your_secure_database_password_here

################################################################################
# JWT CONFIGURATION
# 
# JWT secrets are CRITICAL security settings
# MUST be:
#   - At least 32 characters
#   - Randomly generated
#   - Different between environments
#   - Rotated periodically (every 90 days)
#
# Generate with:
#   openssl rand -base64 32
################################################################################

# JWT Access Token Secret (15-minute expiry)
# Used to sign short-lived access tokens
JWT_ACCESS_SECRET=generate_a_strong_random_secret_min_32_chars_using_openssl

# JWT Refresh Token Secret (7-day expiry)
# Used to sign long-lived refresh tokens
JWT_REFRESH_SECRET=generate_another_strong_random_secret_min_32_chars_using_openssl

# Optionally keep previous secret for rotation grace period
# JWT_ACCESS_SECRET_PREVIOUS=previous_secret_if_rotating

################################################################################
# FRONTEND CONFIGURATION
################################################################################

# CORS Origin - must match your frontend URL exactly
# Development: http://localhost:3000
# Production: https://app.example.com (MUST use HTTPS)
FRONTEND_URL=http://localhost:3000

################################################################################
# COOKIE CONFIGURATION
################################################################################

# Secure flag - enables HTTPS-only transmission
# Development: false (local testing without HTTPS)
# Production: true (MUST be true for HTTPS endpoints)
COOKIE_SECURE=false

# SameSite attribute - CSRF protection
# Options: Strict (most secure), Lax (recommended), None (legacy)
# Strict: Cookie only sent in same-site requests (best for internal apps)
# Lax: Cookie sent with top-level navigation (good UX)
# None: Cookie sent cross-site (requires HTTPS + Secure flag)
COOKIE_SAME_SITE=Lax

################################################################################
# FILE UPLOAD CONFIGURATION
################################################################################

# Local upload directory (dev) or cloud storage path (prod)
# Development: uploads (relative to app root)
# Production: /data/uploads (persistent volume) or S3 bucket name
UPLOAD_DIR=uploads

# Cloud Storage Provider (optional - for production)
# Options: local, aws-s3, azure-blob, gcs
# Default: local (not recommended for production)
UPLOAD_STORAGE_PROVIDER=local

################################################################################
# AWS S3 CONFIGURATION (if using cloud storage)
################################################################################

# AWS S3 Bucket for uploads
# AWS_S3_BUCKET=stratumiq-prod-uploads

# AWS Region
# AWS_REGION=us-east-1

# AWS Access Key ID
# ⚠️  NEVER commit real keys
# Use AWS IAM roles instead when possible
# AWS_ACCESS_KEY_ID=***

# AWS Secret Access Key
# ⚠️  NEVER commit real keys
# Use AWS IAM roles instead when possible
# AWS_SECRET_ACCESS_KEY=***

################################################################################
# REDIS CONFIGURATION (optional - for caching & session storage)
################################################################################

# Redis Server Host
# REDIS_HOST=localhost

# Redis Server Port
# REDIS_PORT=6379

# Redis Password (if required)
# REDIS_PASSWORD=

################################################################################
# LOGGING CONFIGURATION
################################################################################

# Spring Profiles (comma-separated)
# development, staging, production
SPRING_PROFILES_ACTIVE=development

# Log Level
# DEBUG: Verbose logging (dev only)
# INFO: Standard logging
# WARN: Only warnings and errors
# ERROR: Only errors
LOG_LEVEL=INFO

################################################################################
# SERVER CONFIGURATION
################################################################################

# Server Port
# Development: 5000
# Production: 8080 (or any available port)
SERVER_PORT=5000

# Server Servlet Context Path (optional)
# Useful if behind a reverse proxy at /api
# SERVER_SERVLET_CONTEXT_PATH=/api

################################################################################
# DEVELOPMENT TOOLS (Development Only)
################################################################################

# Enable Debug Mode (NEVER in production)
# DEBUG=false

# Spring Boot DevTools enabled
# SPRING_DEVTOOLS_ENABLED=true

################################################################################
# PRODUCTION-SPECIFIC SETTINGS
# (Comment out these sections in development)
################################################################################

# Actuator Endpoints (health, metrics, etc.)
# MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,metrics

# Enable HTTP/2
# SERVER_HTTP2_ENABLED=true

# Connection Pool Size
# SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=20

################################################################################
# NOTES
################################################################################

# 1. Generate strong secrets:
#    openssl rand -base64 32
#
# 2. Keep different values per environment:
#    - Development (localhost)
#    - Staging (staging.example.com)
#    - Production (app.example.com)
#
# 3. Rotate secrets regularly:
#    - JWT secrets: every 90 days
#    - Database passwords: every 180 days
#    - AWS keys: as needed
#
# 4. Never commit the actual .env file:
#    git add .env.example
#    git add .gitignore
#    (add '.env' to .gitignore)
#
# 5. For production deployment:
#    - Use CI/CD secrets management (GitHub, GitLab, etc.)
#    - Use AWS Secrets Manager
#    - Use Kubernetes Secrets
#    - Never hardcode or commit real values
#
# 6. For development:
#    cp .env.example .env
#    # Edit .env with development values
#    # .env is in .gitignore - not committed
#
# 7. Verification checklist:
#    - [ ] All env vars documented
#    - [ ] No real secrets in this file
#    - [ ] .env in .gitignore
#    - [ ] Production secrets in secure storage
#    - [ ] Secrets rotation policy in place
#    - [ ] Access logs track secret usage
